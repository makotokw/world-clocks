{
  "name": "__MSG_APP_TITLE__",
  "description": "__MSG_APP_DESCRIPTION__",
  "version": "@VERSION",
  "manifest_version": 3,
  "default_locale": "en",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_icon": {
      "16": "icon_16.png",
      "128": "icon_128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon_16.png",
    "128": "icon_128.png"
  },
  "permissions": [
    "offscreen"
  ]
}
